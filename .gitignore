# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Recommended additional ignores for Next.js / Node / editors
# OS files
Thumbs.db
ehthumbs.db

# Editor folders
.vscode/
.idea/

# Build output
/dist/
/build/
/out/
/.next/

# Caches
.cache/
.next/cache/

# Storybook
storybook-static/

# Coverage
/coverage/

# Logs
*.log

# Lockfile directories used by package managers (optional)
.pnp/

# Local env files (explicit)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Misc
!.env.example
